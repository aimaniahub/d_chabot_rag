# === Security (required in production) ===
# Site/chat key (Netlify uses the same as RAG_API_KEY)
API_KEY=change_me_long_random_chat_key
# Admin dashboard + uploads (keep secret; only you)
ADMIN_KEY=change_me_long_random_admin_key
# Public Swagger at /docs — keep false
DOCS_ENABLED=false

# === OpenRouter LLM ===
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=https://darvigroup.in
OPENROUTER_SITE_NAME=Darvi RAG Assistant

# === Embeddings ===
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=8
MIN_SCORE=0.22

PORT=8000
CORS_ORIGINS=https://darvigroup.in,https://www.darvigroup.in,http://localhost:3000
AUTO_INGEST_ON_START=true

# DATABASE_URL=${{Postgres.DATABASE_URL}}
