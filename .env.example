# OpenRouter (required) — never commit real keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Free models tried in order if one fails / rate-limits
OPENROUTER_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free

OPENROUTER_SITE_URL=https://darvigroup.in
OPENROUTER_SITE_NAME=Darvi RAG Assistant

# Embeddings (local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=8
MIN_SCORE=0.22

PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=https://darvigroup.in,https://www.darvigroup.in,http://localhost:3000
AUTO_INGEST_ON_START=true

# Railway Postgres
# DATABASE_URL=${{Postgres.DATABASE_URL}}
